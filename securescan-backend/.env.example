# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
# Mettre l'URL ngrok ici quand tu lances le backend
BACKEND_URL=https://xxxx-xxxx-xxxx.ngrok-free.app

# ─── Database (Prisma) ────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:your_password@localhost:3306/securescan"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Temp directories ─────────────────────────────────────────
UPLOAD_DIR=./tmp/uploads
REPO_DIR=./tmp/repos

# ─── GitHub OAuth App ─────────────────────────────────────────
# Créer sur : github.com → Settings → Developer settings → OAuth Apps → New OAuth App
# Homepage URL      : http://localhost:5173
# Callback URL      : https://TON_URL_NGROK/api/githubAuth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Security tools (override if not in PATH) ─────────────────
SEMGREP_BIN=semgrep
TRUFFLEHOG_BIN=trufflehog